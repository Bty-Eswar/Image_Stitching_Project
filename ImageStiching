# SUMMARY FIGURE — Paper Fig. 4 style
# (Input1 | Input2 | Matching Features | Final Output)
# ═══════════════════════════════════════════════════════════
def paper_figure4(img1_bgr, img2_bgr, kp1, kp2, inlier_matches, stitched):
    print("\n[Summary] Generating Paper Fig. 4 style output grid")
    # Column c: matching feature points (inliers only)
    match_img = cv2.drawMatches(img1_bgr, kp1, img2_bgr, kp2,
                                inlier_matches[:50], None,
                                matchColor=(0, 255, 0),
                                flags=cv2.DrawMatchesFlags_NOT_DRAW_SINGLE_POINTS)

    fig, axes = plt.subplots(1, 4, figsize=(22, 5))
    titles = ["a) Input Image 1", "b) Input Image 2",
              "c) Matching Feature Points", "d) Final Output"]
    imgs   = [img1_bgr, img2_bgr, match_img, stitched]

    for ax, title, img in zip(axes, titles, imgs):
        ax.imshow(cv2.cvtColor(img, cv2.COLOR_BGR2RGB))
        ax.set_title(title, fontweight='bold', fontsize=11)
        ax.axis('off')

    plt.suptitle("Paper Fig. 4 — Full Pipeline Output", fontsize=14, fontweight='bold')
    plt.tight_layout()
    plt.savefig("output_Fig4_Summary_Grid.png", dpi=120, bbox_inches='tight')
    plt.show()
    print("  [Saved] output_Fig4_Summary_Grid.png")


# ═══════════════════════════════════════════════════════════
# MAIN PIPELINE
# ═══════════════════════════════════════════════════════════
def run_stitching_pipeline(image1_path, image2_path):
    print("\n" + "╔"+"═"*58+"╗")
    print("║  SEAMLESS PANORAMIC IMAGE STITCHING PIPELINE            ║")
    print("║  Paper: Megha V. & Rajkumar K.K., IJIGSP 2024          ║")
    print("╚"+"═"*58+"╝")

    # ── Load Images
    print(f"\n[Loading] Image 1: {image1_path}")
    print(f"[Loading] Image 2: {image2_path}")

    img1 = cv2.imread(image1_path)
    img2 = cv2.imread(image2_path)

    if img1 is None or img2 is None:
        print("\nERROR: Could not load one or both images.")
        print("  Please update image1_path and image2_path below.")
        return

    # Resize to 512×512 as used in paper (UDIS dataset images are 512×512)
    img1 = cv2.resize(img1, (512, 512))
    img2 = cv2.resize(img2, (512, 512))
    print(f"  Images resized to 512×512 (as per UDIS dataset in paper §6)")

    # Show input images
    fig, ax = plt.subplots(1, 2, figsize=(12, 5))
    ax[0].imshow(cv2.cvtColor(img1, cv2.COLOR_BGR2RGB)); ax[0].set_title("Input Image 1"); ax[0].axis('off')
    ax[1].imshow(cv2.cvtColor(img2, cv2.COLOR_BGR2RGB)); ax[1].set_title("Input Image 2"); ax[1].axis('off')
    plt.suptitle("Input Images", fontweight='bold'); plt.tight_layout()
    plt.savefig("output_Input_Images.png", dpi=120, bbox_inches='tight'); plt.show()

    # ── Module 1: SIFT Feature Detection
    kp1, des1, kp2, des2 = module1_feature_detection(img1, img2)

    # ── Module 2: BF + KNN Feature Matching
    good_matches = module2_feature_matching(img1, img2, kp1, des1, kp2, des2)

    # ── Module 3: RANSAC Outlier Detection
    H, inlier_matches = module3_ransac_outlier_detection(img1, img2, kp1, kp2, good_matches)

    # ── Module 4: Warping + Alpha Blending
    stitched, canvas_img2 = module4_warping_and_blending(img1, img2, H)

    # ── Performance Metrics
    metrics = evaluate_metrics(stitched, canvas_img2)

    # ── Paper Fig. 4 Summary
    paper_figure4(img1, img2, kp1, kp2, inlier_matches, stitched)

    # ── Final Summary
    print("\n" + "="*60)
    print("PIPELINE COMPLETE — SUMMARY")
    print("="*60)
    print(f"  Key points (Image 1)  : {len(kp1)}")
    print(f"  Key points (Image 2)  : {len(kp2)}")
    print(f"  Matches after KNN     : {len(good_matches)}")
    print(f"  Inliers after RANSAC  : {len(inlier_matches)}")
    print(f"  Final panorama shape  : {stitched.shape}")
    print(f"  PSNR  : {metrics['PSNR']:.4f} dB  (paper typical: 30-50 dB)")
    print(f"  SSIM  : {metrics['SSIM']:.4f}     (1 = perfect)")
    print(f"  RMSE  : {metrics['RMSE']:.4f}")
    print(f"  MSE   : {metrics['MSE']:.4f}")
    print(f"  UIQI  : {metrics['UIQI']:.4f}     (1 = perfect)")

    # Save stitched result
    cv2.imwrite("output_Final_Stitched_Panorama.jpg", stitched)
    print("\n  Final panorama saved: output_Final_Stitched_Panorama.jpg")
    print("\n  All step-by-step outputs saved as output_*.png files")


