"""
============================================================
SEAMLESS PANORAMIC IMAGE STITCHING
Based on: "Seamless Panoramic Image Stitching Based on Invariant
Feature Detector and Image Blending"
by Megha V. and Rajkumar K.K.
Published in I.J. Image, Graphics and Signal Processing, 2024, 4, 30-41

Paper Modules:
  Module 1: Feature Detection using SIFT
  Module 2: Feature Matching using Brute-Force Matcher with KNN
  Module 3: Outlier Detection using RANSAC
  Module 4: Image Warping and Alpha Blending

Metrics: PSNR, SSIM, RMSE, MSE, UIQI
============================================================
"""

import cv2
import numpy as np
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
import os
import sys
from math import log10, sqrt


# ─────────────────────────────────────────────────────────
# UTILITY: show an image inline in matplotlib
# ─────────────────────────────────────────────────────────
def show(title, img, cmap=None):
    plt.figure(figsize=(10, 5))
    if len(img.shape) == 2 or cmap == 'gray':
        plt.imshow(img, cmap='gray')
    else:
        plt.imshow(cv2.cvtColor(img, cv2.COLOR_BGR2RGB))
    plt.title(title, fontsize=14, fontweight='bold')
    plt.axis('off')
    plt.tight_layout()
    plt.savefig(f"output_{title.replace(' ', '_').replace('/', '_')}.png",
                dpi=120, bbox_inches='tight')
    plt.show()
    print(f"  [Saved] output_{title.replace(' ', '_').replace('/', '_')}.png")


# ═══════════════════════════════════════════════════════════
# MODULE 1 — FEATURE DETECTION USING SIFT
# Paper Section 4.1
# ═══════════════════════════════════════════════════════════
def module1_feature_detection(img1_bgr, img2_bgr):
    """
    Steps (paper §4.1):
      1. Convert color images to grayscale (preprocessing)
      2. Build scale-space using Gaussian convolution  L(x,y,σ) = G(x,y,σ)*I(x,y)
      3. Compute Difference-of-Gaussian (DoG)          D(x,y) = L(x,y,kσ) − L(x,y,σ)
      4. Detect scale-space extrema (key points)
      5. Eliminate low-contrast + edge key points
      6. Assign orientation to each key point
      7. Build 128-dim feature descriptor (4×4 cells × 8-bin histogram = 128)
    """
    print("\n" + "="*60)
    print("MODULE 1: FEATURE DETECTION USING SIFT")
    print("="*60)

    # ── Step 1: Preprocessing – convert to grayscale (paper §4.1)
    print("\n[Step 1] Converting color images to grayscale (preprocessing)")
    gray1 = cv2.cvtColor(img1_bgr, cv2.COLOR_BGR2GRAY)
    gray2 = cv2.cvtColor(img2_bgr, cv2.COLOR_BGR2GRAY)
    print(f"  Image 1 original shape : {img1_bgr.shape}")
    print(f"  Image 1 grayscale shape: {gray1.shape}")
    print(f"  Image 2 original shape : {img2_bgr.shape}")
    print(f"  Image 2 grayscale shape: {gray2.shape}")

    # Show grayscale images
    fig, axes = plt.subplots(1, 2, figsize=(12, 5))
    axes[0].imshow(gray1, cmap='gray'); axes[0].set_title("Gray Image 1"); axes[0].axis('off')
    axes[1].imshow(gray2, cmap='gray'); axes[1].set_title("Gray Image 2"); axes[1].axis('off')
    plt.suptitle("Step 1 Output: Grayscale Conversion", fontweight='bold')
    plt.tight_layout()
    plt.savefig("output_Step1_Grayscale.png", dpi=120, bbox_inches='tight')
    plt.show()

    # ── Step 2–7: SIFT feature detection + descriptor extraction
    # SIFT implements all paper steps:
    # scale-space → DoG → extrema → key point localization →
    # orientation assignment → 128-dim descriptor
    print("\n[Step 2-7] SIFT: Scale-Space → DoG → Extrema → Orientation → Descriptor")
    sift = cv2.SIFT_create()
    kp1, des1 = sift.detectAndCompute(gray1, None)
    kp2, des2 = sift.detectAndCompute(gray2, None)

    print(f"\n  Key points detected in Image 1 : {len(kp1)}")
    print(f"  Key points detected in Image 2 : {len(kp2)}")
    print(f"  Descriptor length per keypoint  : {des1.shape[1]}  (4×4 cells × 8-bin = 128)")

    # Draw key points on images
    img1_kp = cv2.drawKeypoints(gray1, kp1, None,
                                flags=cv2.DRAW_MATCHES_FLAGS_DRAW_RICH_KEYPOINTS)
    img2_kp = cv2.drawKeypoints(gray2, kp2, None,
                                flags=cv2.DRAW_MATCHES_FLAGS_DRAW_RICH_KEYPOINTS)

    fig, axes = plt.subplots(1, 2, figsize=(14, 6))
    axes[0].imshow(img1_kp, cmap='gray')
    axes[0].set_title(f"Image 1 — {len(kp1)} Key Points"); axes[0].axis('off')
    axes[1].imshow(img2_kp, cmap='gray')
    axes[1].set_title(f"Image 2 — {len(kp2)} Key Points"); axes[1].axis('off')
    plt.suptitle("Step 2-7 Output: SIFT Key Points (scale + orientation shown)", fontweight='bold')
    plt.tight_layout()
    plt.savefig("output_Step2_7_SIFT_Keypoints.png", dpi=120, bbox_inches='tight')
    plt.show()

    # Print descriptor statistics (paper mentions 128-dim vector)
    print(f"\n  Descriptor matrix shape (Image 1): {des1.shape}  [N keypoints × 128 dims]")
    print(f"  Descriptor matrix shape (Image 2): {des2.shape}")
    print(f"  Sample descriptor (first 16 dims of kp1[0]):\n  {des1[0, :16]}")

    return kp1, des1, kp2, des2


# ═══════════════════════════════════════════════════════════
# MODULE 2 — FEATURE MATCHING: Brute-Force + KNN
# Paper Section 4.2
# ═══════════════════════════════════════════════════════════
def module2_feature_matching(img1_bgr, img2_bgr, kp1, des1, kp2, des2):
    """
    Steps (paper §4.2):
      1. Brute-Force (BF) matcher: compare every descriptor in img1
         against every descriptor in img2 using distance measure.
      2. KNN with k=2: find 2 nearest neighbours for each descriptor.
      3. Lowe's ratio test with threshold = 0.8 (paper §4.2):
         If dist(nearest) / dist(2nd nearest) < 0.8 → good match, else discard.
      4. Sort inliers by descriptor distance.
    """
    print("\n" + "="*60)
    print("MODULE 2: FEATURE MATCHING — BF Matcher with KNN")
    print("="*60)

    # ── Step 1-2: BF Matcher + kNN (k=2) as stated in paper
    print("\n[Step 1-2] Brute-Force Matcher with KNN (k=2)")
    bf = cv2.BFMatcher(cv2.NORM_L2)          # L2 distance for SIFT (paper §4.2)
    matches_knn = bf.knnMatch(des1, des2, k=2)   # k=2 as specified in paper
    print(f"  Total KNN match pairs found: {len(matches_knn)}")

    # ── Step 3: Lowe's ratio test — threshold = 0.8 (paper §4.2)
    print("\n[Step 3] Lowe Ratio Test (threshold = 0.8 as per paper §4.2)")
    good_matches = []
    for m, n in matches_knn:
        if m.distance < 0.8 * n.distance:   # threshold = 0.8 from paper
            good_matches.append(m)
    good_matches = sorted(good_matches, key=lambda x: x.distance)  # sort by distance

    print(f"  Matches after ratio test: {len(good_matches)}")
    print(f"  Discarded (outlier candidates): {len(matches_knn) - len(good_matches)}")
    if good_matches:
        print(f"  Best match distance : {good_matches[0].distance:.4f}")
        print(f"  Worst match distance: {good_matches[-1].distance:.4f}")

    # ── Step 4: Visualise all good matches
    img_matches = cv2.drawMatches(img1_bgr, kp1, img2_bgr, kp2,
                                  good_matches[:80], None,
                                  flags=cv2.DrawMatchesFlags_NOT_DRAW_SINGLE_POINTS)
    show("Module 2 — BF+KNN Feature Matches (top 80)", img_matches)

    return good_matches


# ═══════════════════════════════════════════════════════════
# MODULE 3 — OUTLIER DETECTION USING RANSAC
# Paper Section 4.3
# ═══════════════════════════════════════════════════════════
def module3_ransac_outlier_detection(img1_bgr, img2_bgr, kp1, kp2, good_matches):
    """
    Steps (paper §4.3):
      RANSAC loop:
        1. Choose random seed group of points.
        2. Compute transformation matrix (Homography H).
        3. Find inliers that fit the transformation.
        4. If enough inliers, recompute least-squares H from all inliers.
        5. Keep transformation with most inliers.
      Returns: Homography matrix H, inlier mask, filtered match list
    """
    print("\n" + "="*60)
    print("MODULE 3: RANSAC-BASED OUTLIER DETECTION")
    print("="*60)

    if len(good_matches) < 4:
        raise ValueError("Need at least 4 matches to compute Homography.")

    # Extract point coordinates from key point objects
    src_pts = np.float32([kp1[m.queryIdx].pt for m in good_matches]).reshape(-1, 1, 2)
    dst_pts = np.float32([kp2[m.trainIdx].pt for m in good_matches]).reshape(-1, 1, 2)

    print(f"\n[Step 1-5] Running RANSAC to compute Homography H")
    print(f"  Input matches to RANSAC: {len(good_matches)}")

    # RANSAC as described in paper §4.3
    H, mask = cv2.findHomography(src_pts, dst_pts,
                                  cv2.RANSAC,
                                  ransacReprojThreshold=5.0)
    mask = mask.ravel()

    inlier_matches  = [good_matches[i] for i in range(len(good_matches)) if mask[i] == 1]
    outlier_matches = [good_matches[i] for i in range(len(good_matches)) if mask[i] == 0]

    print(f"  Inliers  after RANSAC: {len(inlier_matches)}")
    print(f"  Outliers removed      : {len(outlier_matches)}")
    print(f"\n  Homography Matrix H:\n{H}")

    # ── Visualise: inliers (green) vs outliers (red)
    img_inliers = cv2.drawMatches(img1_bgr, kp1, img2_bgr, kp2,
                                   inlier_matches[:60], None,
                                   matchColor=(0, 255, 0),
                                   flags=cv2.DrawMatchesFlags_NOT_DRAW_SINGLE_POINTS)
    show("Module 3 — RANSAC Inliers (green, top 60)", img_inliers)

    if outlier_matches:
        img_outliers = cv2.drawMatches(img1_bgr, kp1, img2_bgr, kp2,
                                        outlier_matches[:30], None,
                                        matchColor=(0, 0, 255),
                                        flags=cv2.DrawMatchesFlags_NOT_DRAW_SINGLE_POINTS)
        show("Module 3 — RANSAC Outliers removed (red, top 30)", img_outliers)

    return H, inlier_matches


# ═══════════════════════════════════════════════════════════
# MODULE 4 — IMAGE WARPING + ALPHA BLENDING
# Paper Section 4.4
# ═══════════════════════════════════════════════════════════
def module4_warping_and_blending(img1_bgr, img2_bgr, H):
    """
    Steps (paper §4.4):
      1. Perspective Warping:
         - Compute perspective transformation from Homography H.
         - Apply warpPerspective to img1 (source) into the coordinate frame of img2.
      2. Alpha Blending (paper eq. 6):
         I = α·I1 + (1−α)·I2   with  α = 0.5
         - Overlapping region uses equal contribution from both images.
         - α = 0.5 eliminates visible seams (paper §4.4).
    """
    print("\n" + "="*60)
    print("MODULE 4: IMAGE WARPING + ALPHA BLENDING")
    print("="*60)

    h1, w1 = img1_bgr.shape[:2]
    h2, w2 = img2_bgr.shape[:2]

    # ── Step 1: Perspective Warping (paper §4.4)
    print("\n[Step 1] Perspective Warping using Homography H")

    # Compute bounding box of the warped image
    corners_img1 = np.float32([[0,0],[w1,0],[w1,h1],[0,h1]]).reshape(-1,1,2)
    corners_img2 = np.float32([[0,0],[w2,0],[w2,h2],[0,h2]]).reshape(-1,1,2)
    warped_corners = cv2.perspectiveTransform(corners_img1, H)
    all_corners = np.concatenate([corners_img2, warped_corners], axis=0)

    [xmin, ymin] = np.int32(all_corners.min(axis=0).ravel() - 0.5)
    [xmax, ymax] = np.int32(all_corners.max(axis=0).ravel() + 0.5)

    # Translation to shift negative coordinates to positive
    t = [-xmin, -ymin]
    H_t = np.array([[1, 0, t[0]],
                    [0, 1, t[1]],
                    [0, 0, 1  ]], dtype=np.float64)

    out_w = xmax - xmin
    out_h = ymax - ymin
    print(f"  Output canvas size: {out_w} × {out_h} pixels")

    # Warp img1 onto the canvas
    warped_img1 = cv2.warpPerspective(img1_bgr, H_t @ H, (out_w, out_h))

    # Place img2 onto the canvas
    canvas_img2 = np.zeros((out_h, out_w, 3), dtype=np.uint8)
    canvas_img2[t[1]:t[1]+h2, t[0]:t[0]+w2] = img2_bgr

    show("Module 4 Step 1a — Warped Image 1 (perspective warping)", warped_img1)
    show("Module 4 Step 1b — Image 2 placed on canvas", canvas_img2)

    # ── Step 2: Alpha Blending (paper eq. 6: I = α·I1 + (1−α)·I2, α=0.5)
    print("\n[Step 2] Alpha Blending  →  I = α·I1 + (1−α)·I2  with α = 0.5")
    alpha = 0.5   # paper §4.4: α = 0.5 for seam elimination

    # Build masks to identify regions
    mask_warped = (warped_img1.sum(axis=2) > 0).astype(np.float32)
    mask_canvas = (canvas_img2.sum(axis=2) > 0).astype(np.float32)
    overlap     = (mask_warped * mask_canvas)   # pixels present in BOTH images

    # Construct the stitched image:
    #   - Overlap region: I = 0.5·I1 + 0.5·I2  (paper eq. 6)
    #   - Non-overlap:    take whichever image has pixels
    stitched = np.zeros_like(warped_img1, dtype=np.float32)
    for c in range(3):
        w1_ch = warped_img1[:, :, c].astype(np.float32)
        w2_ch = canvas_img2[:, :, c].astype(np.float32)
        stitched[:, :, c] = (
            overlap        * (alpha * w1_ch + (1 - alpha) * w2_ch) +  # overlap
            (1 - overlap)  * mask_warped * w1_ch +                     # only img1
            (1 - overlap)  * mask_canvas * w2_ch                       # only img2
        )

    stitched = np.clip(stitched, 0, 255).astype(np.uint8)

    show("Module 4 Step 2 — Final Stitched Panorama (Alpha Blended α=0.5)", stitched)
    print(f"  Final stitched image shape: {stitched.shape}")

    # Show the overlap region highlighted
    overlap_vis = canvas_img2.copy()
    overlap_mask_3ch = np.stack([overlap]*3, axis=2).astype(np.uint8)
    overlap_vis[overlap.astype(bool)] = [0, 255, 0]
    show("Module 4 — Overlap Region (green)", overlap_vis)

    return stitched, canvas_img2


