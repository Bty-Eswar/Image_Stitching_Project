# PERFORMANCE EVALUATION METRICS
# Paper Section 5 — PSNR, SSIM, RMSE, MSE, UIQI
# ═══════════════════════════════════════════════════════════

def compute_mse(img1, img2):
    """MSE (paper eq. 14): MSE = Σ[I1(m,n)−I2(m,n)]² / (M×N)"""
    img1 = img1.astype(np.float64)
    img2 = img2.astype(np.float64)
    M, N = img1.shape[:2]
    return np.sum((img1 - img2) ** 2) / (M * N * (img1.shape[2] if img1.ndim == 3 else 1))


def compute_psnr(img1, img2):
    """PSNR (paper eq. 7): PSNR = 10·log10(R²/MSE), R=255 for 8-bit"""
    mse = compute_mse(img1, img2)
    if mse == 0:
        return float('inf')
    R = 255.0
    return 10 * log10((R ** 2) / mse)


def compute_rmse(img1, img2):
    """RMSE (paper eq. 9): RMSE = sqrt(Σ(Pi−Oi)²/n)"""
    return sqrt(compute_mse(img1, img2))


def compute_ssim(img1, img2):
    """
    SSIM (paper eq. 8):
    SSIM(x,y) = (2μxμy+C1)(2σxy+C2) / (μx²+μy²+C1)(σx²+σy²+C2)
    """
    img1 = img1.astype(np.float64)
    img2 = img2.astype(np.float64)

    C1 = (0.01 * 255) ** 2
    C2 = (0.03 * 255) ** 2

    if img1.ndim == 3:
        ssim_vals = []
        for c in range(img1.shape[2]):
            ssim_vals.append(_ssim_channel(img1[:,:,c], img2[:,:,c], C1, C2))
        return np.mean(ssim_vals)
    return _ssim_channel(img1, img2, C1, C2)


def _ssim_channel(ch1, ch2, C1, C2):
    mu_x   = np.mean(ch1)
    mu_y   = np.mean(ch2)
    sigma_x  = np.std(ch1)
    sigma_y  = np.std(ch2)
    sigma_xy = np.mean((ch1 - mu_x) * (ch2 - mu_y))
    numerator   = (2*mu_x*mu_y + C1) * (2*sigma_xy + C2)
    denominator = (mu_x**2 + mu_y**2 + C1) * (sigma_x**2 + sigma_y**2 + C2)
    return numerator / denominator


def compute_uiqi(img1, img2):
    """
    UIQI (paper eq. 10-13):
    l(x,y) = 2μxμy / (μx²+μy²)
    c(x,y) = 2σxσy / (σx²+σy²)
    s(x,y) = σxy / (σx·σy)
    UIQI = (4·μx·μy·σxy) / ((μx²+μy²)·(σx²+σy²))
    """
    img1 = img1.astype(np.float64)
    img2 = img2.astype(np.float64)
    if img1.ndim == 3:
        uiqi_vals = [_uiqi_channel(img1[:,:,c], img2[:,:,c]) for c in range(img1.shape[2])]
        return np.mean(uiqi_vals)
    return _uiqi_channel(img1, img2)


def _uiqi_channel(ch1, ch2):
    mu_x   = np.mean(ch1)
    mu_y   = np.mean(ch2)
    sigma_x  = np.std(ch1)
    sigma_y  = np.std(ch2)
    sigma_xy = np.mean((ch1 - mu_x) * (ch2 - mu_y))
    denom = (mu_x**2 + mu_y**2) * (sigma_x**2 + sigma_y**2)
    if denom == 0:
        return 0.0
    return (4 * mu_x * mu_y * sigma_xy) / denom


def evaluate_metrics(stitched, reference):
    """
    Compute all 5 metrics from paper §5 on the overlapping region.
    Crops to the minimum common size for comparison.
    """
    print("\n" + "="*60)
    print("PERFORMANCE EVALUATION METRICS (Paper §5)")
    print("="*60)

    h = min(stitched.shape[0], reference.shape[0])
    w = min(stitched.shape[1], reference.shape[1])
    s = stitched[:h, :w]
    r = reference[:h, :w]

    psnr  = compute_psnr(s, r)
    ssim  = compute_ssim(s, r)
    rmse  = compute_rmse(s, r)
    mse   = compute_mse(s, r)
    uiqi  = compute_uiqi(s, r)

    print(f"\n  PSNR  (↑ better, range 30-50 dB): {psnr:.4f} dB")
    print(f"  SSIM  (↑ better, range 0-1)      : {ssim:.4f}")
    print(f"  RMSE  (↓ better)                  : {rmse:.4f}")
    print(f"  MSE   (↓ better)                  : {mse:.4f}")
    print(f"  UIQI  (↑ better, range 0-1)       : {uiqi:.4f}")

    # Bar chart for metrics (similar to paper Fig. 5)
    metrics = {'PSNR (dB)': psnr, 'SSIM': ssim*100, 'RMSE': rmse, 'MSE': mse/100, 'UIQI': uiqi*100}
    fig, axes = plt.subplots(1, 5, figsize=(18, 4))
    colors = ['steelblue', 'darkorange', 'tomato', 'purple', 'seagreen']
    labels = ['PSNR\n(dB)', 'SSIM\n(×100)', 'RMSE', 'MSE\n(÷100)', 'UIQI\n(×100)']
    vals   = [psnr, ssim*100, rmse, mse/100, uiqi*100]
    for i, ax in enumerate(axes):
        ax.bar(['Img Set'], [vals[i]], color=colors[i], width=0.4)
        ax.set_title(labels[i], fontweight='bold')
        ax.set_ylim(0, max(vals[i]*1.3, 0.1))
        ax.text(0, vals[i]+vals[i]*0.05, f"{vals[i]:.2f}", ha='center', fontsize=10)
    plt.suptitle("Performance Metrics (Paper §5 — Fig. 5 style)", fontweight='bold', fontsize=13)
    plt.tight_layout()
    plt.savefig("output_Performance_Metrics.png", dpi=120, bbox_inches='tight')
    plt.show()

    return {'PSNR': psnr, 'SSIM': ssim, 'RMSE': rmse, 'MSE': mse, 'UIQI': uiqi}


