# DEMO MODE — Generate synthetic overlapping images if no
# real images are provided (for testing the full pipeline)
# ═══════════════════════════════════════════════════════════
def create_demo_images():
    """
    Create two synthetic overlapping images for demo/testing.
    Replace image1_path/image2_path with your own images for real use.
    """
    print("\n[Demo] Creating synthetic overlapping test images...")
    np.random.seed(42)

    # Base image with patterns (simulating a real scene)
    base = np.zeros((512, 768, 3), dtype=np.uint8)
    # Gradient background
    for i in range(512):
        base[i, :] = [int(100 + i*0.3), int(80 + i*0.2), int(60 + i*0.1)]

    # Add rectangles (buildings-like)
    cv2.rectangle(base, (50, 100), (180, 400), (200, 180, 160), -1)
    cv2.rectangle(base, (200, 150), (320, 400), (180, 200, 170), -1)
    cv2.rectangle(base, (350, 80), (500, 400), (160, 160, 200), -1)
    cv2.rectangle(base, (530, 120), (700, 400), (190, 170, 150), -1)

    # Windows
    for bx, by, bw, bh in [(50,100,130,300),(200,150,120,250),(350,80,150,320),(530,120,170,280)]:
        for wy in range(by+20, by+bh-20, 40):
            for wx in range(bx+10, bx+bw-10, 30):
                cv2.rectangle(base, (wx, wy), (wx+20, wy+25), (220, 230, 255), -1)

    # Circles (trees/lights)
    for cx, cy, r, col in [(100,430,30,(30,120,30)),(280,440,25,(20,100,20)),
                            (450,420,35,(40,130,40)),(620,435,28,(25,110,25))]:
        cv2.circle(base, (cx, cy), r, col, -1)

    # Text-like features for SIFT
    for i in range(0, 768, 60):
        cv2.line(base, (i, 450), (i, 512), (100, 100, 100), 2)

    # Image 1: left portion with overlap
    img1 = base[:, :512].copy()
    # Image 2: right portion (with overlap from 256 to 512 of base)
    img2 = base[:, 256:].copy()
    img2 = cv2.resize(img2, (512, 512))
    img1 = cv2.resize(img1, (512, 512))

    # Add slight brightness difference (simulating different illumination — paper §1)
    img2 = np.clip(img2.astype(np.float32) * 1.1, 0, 255).astype(np.uint8)

    cv2.imwrite("demo_image1.jpg", img1)
    cv2.imwrite("demo_image2.jpg", img2)
    print("  demo_image1.jpg and demo_image2.jpg created.")
    return "demo_image1.jpg", "demo_image2.jpg"


